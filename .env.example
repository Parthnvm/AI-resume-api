# ─── AI Resume Screener — Environment Variables ──────────────────────────────
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# On Render / Railway / Fly.io, set these in the platform's environment dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask core ────────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-key-here

# Set to "production" on cloud hosts; "development" for local dev
FLASK_ENV=development

# Port the dev server listens on (gunicorn uses $PORT set by the platform)
PORT=5000

# ── AI Providers ──────────────────────────────────────────────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq (fallback) — https://console.groq.com/keys
# Free tier: 30 RPM / 14,400 RPD — much higher headroom than Gemini free tier
GROQ_API_KEY=your-groq-api-key-here

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Firebase Console → Project Settings → General → Your apps → Web API Key
FIREBASE_API_KEY=your-firebase-web-api-key-here

# ── Database (optional) ───────────────────────────────────────────────────────
# Leave blank to use the default SQLite database (sufficient for single-server).
# Set to a PostgreSQL connection string for multi-worker / managed DB deployments.
# Example (Render Postgres):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── File uploads (optional) ───────────────────────────────────────────────────
# Absolute path where uploaded resumes are stored.
# On Render, mount a persistent disk and set this to the disk's mount path,
# e.g. /opt/render/project/src/resumes
# Leave blank to use the default ./resumes folder (fine for local dev).
UPLOAD_DIR=

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
